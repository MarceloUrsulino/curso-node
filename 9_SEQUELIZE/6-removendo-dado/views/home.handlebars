<h1>Usuários cadastrados:</h1>
<div class="class-container">
    {{#each users}}
    <div class="item">
        <h2>{{this.name}}</h2>
        <p>{{this.occupation}}</p>
        <div class="actions">
            <a href="/users/{{this.id}}">ver detalhes</a>
            <form action="/users/delete/{{this.id}}" method="POST">
            <input type="submit" value="Excluir" class="delete-btr">
            </form>
        </div>
    </div>
    {{/each}}
</div>
